# ── Application Server ────────────────────────────────
# Host address for the application server
# Default 127.0.0.1 is local-only. Set to 0.0.0.0 to make the app
# accessible to other computers on your local network.
APP_HOST=127.0.0.1

# Port for the application server
APP_PORT=8080

# ── vLLM Local Inference ──────────────────────────────
# Base URL for the local vLLM server (must include /v1 path)
VLLM_BASE_URL=http://localhost:8000/v1

# Model name served by vLLM for conversations (must match --served-model-name)
CONVERSATION_MODEL=MythoMax-L2-13B

# ── Situation Generation (Local Inference) ────────────
# Base URL for the vLLM server used for situation generation
# Can point to a different vLLM instance / model than conversations
SITUATION_MODEL_URL=http://localhost:8000/v1

# Model name for generating persona situations
SITUATION_MODEL=MythoMax-L2-13B

# ── OpenAI API (not used in Feature 1) ─────────────────
# API key for synthesis and scoring (Features 3-4)
OPENAI_API_KEY=

# Model for synthesis (Feature 3)
SYNTHESIS_MODEL=gpt-4o

# Model for scoring (Feature 4)
SCORING_MODEL=o3

# Temperature for synthesis (omit or leave empty to use model default)
# Note: gpt-5-mini only supports its default temperature (1)
# SYNTHESIS_TEMPERATURE=0.4

# Temperature for scoring (omit or leave empty to use model default)
# Note: o3 only supports its default temperature (1)
# SCORING_TEMPERATURE=0.3

# ── Jacket Copy Generation ────────────────────────────
# Base URL for the jacket copy API (omit to use default OpenAI URL)
# JACKET_COPY_BASE_URL=https://api.openai.com/v1

# Model for jacket copy generation
JACKET_COPY_MODEL=gpt-4o

# Temperature for jacket copy generation (omit for model default)
JACKET_COPY_TEMPERATURE=0.7

# ── Domain ────────────────────────────────────────────
# Active domain configuration (sci-fi-concepts, product-design)
ACTIVE_DOMAIN=sci-fi-concepts

# ── Database ──────────────────────────────────────────
# Path to SQLite database file
DATABASE_PATH=data/yield_engine.db

# ── Conversation Defaults ─────────────────────────────
# Default number of turns per agent (10 total exchanges)
DEFAULT_TURNS=5

# ── Inference Parameters ──────────────────────────────
# Temperature for conversation generation (0.0-2.0)
CONVERSATION_TEMPERATURE=0.9

# Repetition penalty for vLLM (1.0 = no penalty)
CONVERSATION_REPETITION_PENALTY=1.15

# Maximum tokens per turn
CONVERSATION_MAX_TOKENS=150
